# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.qss text eol=lf
*.bat text eol=crlf
*.sh text eol=lf

# Binary files
*.mp4 binary
*.mov binary
*.avi binary
*.mkv binary
*.webm binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Files that should always have LF line endings on checkout
*.py text eol=lf
*.sh text eol=lf

# Files that should always have CRLF line endings on checkout
*.bat text eol=crlf
